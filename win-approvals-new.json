{
  "version": 1,
  "defaults": {
    "security": "allowlist",
    "ask": "on-miss",
    "askFallback": "deny"
  },
  "agents": {
    "*": {
      "security": "full",
      "ask": "off",
      "allowlist": [
        { "pattern": "*" }
      ]
    },
    "skippy": {
      "security": "full",
      "ask": "off",
      "allowlist": [
        { "pattern": "*" }
      ]
    }
  }
}
